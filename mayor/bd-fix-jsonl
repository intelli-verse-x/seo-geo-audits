#!/usr/bin/env python3
"""
Beads JSONL fix utility: Transform depends_on_id to proper source columns.

This fixes the recurring issue where beads exports the generated column
depends_on_id, which cannot be imported back into Dolt.

Usage:
  bd-fix-jsonl              # Fix /gt/.beads/issues.jsonl in place
  bd-fix-jsonl --check      # Check if fix is needed
  bd-fix-jsonl path.jsonl   # Fix specific file
"""
import json
import sys
import os
import shutil

def fix_dependency(dep):
    """Transform dependency to use source columns."""
    if 'depends_on_id' not in dep:
        return dep, False

    dep_id = dep.pop('depends_on_id')

    if dep_id.startswith('hq-wisp-') or dep_id.startswith('audits-wisp-'):
        dep['depends_on_wisp_id'] = dep_id
    elif dep_id.startswith('http://') or dep_id.startswith('https://'):
        dep['depends_on_external'] = dep_id
    else:
        dep['depends_on_issue_id'] = dep_id

    return dep, True

def fix_issue(issue):
    """Fix dependencies in an issue."""
    modified = False
    if 'dependencies' in issue and isinstance(issue['dependencies'], list):
        fixed_deps = []
        for d in issue['dependencies']:
            fixed, changed = fix_dependency(d.copy())
            fixed_deps.append(fixed)
            if changed:
                modified = True
        issue['dependencies'] = fixed_deps
    return issue, modified

def check_needs_fix(jsonl_path):
    """Check if the JSONL file needs fixing."""
    needs_fix = False
    with open(jsonl_path, 'r') as f:
        for line in f:
            if not line.strip():
                continue
            issue = json.loads(line)
            if 'dependencies' in issue:
                for dep in issue['dependencies']:
                    if 'depends_on_id' in dep:
                        needs_fix = True
                        break
            if needs_fix:
                break
    return needs_fix

def main():
    check_only = '--check' in sys.argv

    if len(sys.argv) > 1 and sys.argv[1] not in ['--check']:
        jsonl_path = sys.argv[1]
    else:
        jsonl_path = '/gt/.beads/issues.jsonl'

    if not os.path.exists(jsonl_path):
        print(f"Error: {jsonl_path} not found", file=sys.stderr)
        sys.exit(1)

    if check_only:
        if check_needs_fix(jsonl_path):
            print("NEEDS_FIX")
            sys.exit(1)
        else:
            print("OK")
            sys.exit(0)

    # Fix the file
    temp_path = jsonl_path + '.tmp'
    modified_count = 0

    try:
        with open(jsonl_path, 'r') as f_in, open(temp_path, 'w') as f_out:
            for line in f_in:
                if not line.strip():
                    continue
                issue = json.loads(line)
                fixed, modified = fix_issue(issue)
                if modified:
                    modified_count += 1
                f_out.write(json.dumps(fixed) + '\n')

        # Atomic replace
        shutil.move(temp_path, jsonl_path)

        if modified_count > 0:
            print(f"✓ Fixed {modified_count} issues in {jsonl_path}")
        else:
            print(f"✓ No changes needed in {jsonl_path}")

        sys.exit(0)
    except Exception as e:
        if os.path.exists(temp_path):
            os.remove(temp_path)
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
